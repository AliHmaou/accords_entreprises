# Fichier d'environnement (.env) pour le pipeline des accords professionnels

# Paramètres de l'API LLM (au choix : OpenAI, Groq, Azure, etc.)
# OPENAI_API_KEY=votre_cle_openai
# GROQ_API_KEY=votre_cle_groq
LLM_API_KEY=

# URL de base de l'API (optionnel, utile pour Azure ou d'autres endpoints custom)
# LLM_BASE_URL=https://api.openai.com/v1
LLM_BASE_URL=

# Modèle à utiliser
# Par défaut : gpt-4o-mini
LLM_MODEL=gpt-4o-mini

# Filtre temporel (Année par défaut pour l'analyse IA)
ANNEE_FILTRE_DEFAUT=2025

# Hugging Face configuration pour l'export (Jalon 4)
# Remplacez par votre token write et le repo id de votre dataset
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxx
HF_TOKEN=
HF_REPO_ID=alihmaou/ACCO_ACCORDS_PROFESSIONNELS_MOBILITES

# ---------------------------------------------------------
# Configuration GitHub (Optionnel, pour vos push distants)
# ---------------------------------------------------------
# Renseignez votre Personal Access Token (PAT)
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxx
GITHUB_TOKEN=
# Votre nom d'utilisateur et le nom de votre repo cible
GITHUB_USERNAME=AliHmaou
GITHUB_REPO=accords_entreprise
